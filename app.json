{
  "expo": {
    "name": "Climora: Weather Forecast",
    "slug": "climora-weather-forecast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "climora",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pushkaradhikari.climora",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Climora uses your location to provide accurate local weather forecasts."
      }
    },
    "android": {
      "package": "com.pushkaradhikari.climora",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-updates"
    ],
    "updates": {
      "url": "https://u.expo.dev/0cbfdbf8-ab6d-4387-a51e-2564fc505a70",
      "fallbackToCacheTimeout": 30000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0cbfdbf8-ab6d-4387-a51e-2564fc505a70"
      }
    }
  }
}
